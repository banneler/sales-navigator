{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "functions": {
    "api/router.js": {
      "includeFiles": "docs/{gpc-training-corpus-structured.md,router-corpus/by-module/**}",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth/[...all]"
    }
  ],
  "redirects": [
    {
      "source": "/favicon.ico",
      "destination": "/favicon.svg",
      "permanent": false
    }
  ]
}
