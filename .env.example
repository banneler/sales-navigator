# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL of the app (no trailing slash), e.g. https://your-project.vercel.app
BETTER_AUTH_URL=

# Vercel Postgres / Neon — pooled connection string (POSTGRES_URL in Vercel dashboard)
POSTGRES_URL=

# Optional: extra allowed origins (comma-separated), e.g. preview URLs
# BETTER_AUTH_TRUSTED_ORIGINS=https://your-project-git-main.vercel.app
