{
  "manifest_version": 3,
  "name": "GPC SharePoint Module Builder",
  "description": "Capture GPC Sales SharePoint pages (screenshots + structure) to assemble Sales-Navigator training modules.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "sidePanel",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://gpcom.sharepoint.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "SharePoint Module Builder"
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://gpcom.sharepoint.com/*"],
      "js": ["lib/scroll-root-browser.js", "content/scrape.js"],
      "run_at": "document_idle"
    }
  ]
}
